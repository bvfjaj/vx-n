-- Improved Request Function
local function sendWebhook()
    local success, err = pcall(function()
        local req = (syn and syn.request) 
                 or (http_request) 
                 or (request) 
                 or (HttpService.RequestAsync and function(opts) return HttpService:RequestAsync(opts) end)
        
        if not req then
            error("No HTTP request function found")
        end

        local response = req({
            Url = webhook,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })

        print("Webhook Response:", response and response.StatusCode or "No response")
        return response
    end)

    if not success then
        warn("Webhook failed:", err)
    else
        print("✅ Webhook sent successfully!")
    end
end

